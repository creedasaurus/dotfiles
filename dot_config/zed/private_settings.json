// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed"
  },
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "git_panel": {
    "tree_view": true,
  },
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
    },
  },
  "colorize_brackets": true,
  "use_system_window_tabs": true,
  "rounded_selection": true,
  "lsp_document_colors": "inlay",
  "inline_code_actions": false,
  "minimap": {
    "show": "never",
  },
  "title_bar": {
    "show_user_picture": false,
    "show_branch_icon": true,
  },
  "search": {
    "button": false,
    "case_sensitive": true,
    "center_on_match": true,
  },
  "project_panel": {
    "starts_open": true,
    "sticky_scroll": true,
    "dock": "left",
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "scrollbar": {
    "show": "auto",
  },
  "terminal": {
    "keep_selection_on_copy": false,
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
  },
  "ui_font_family": "Monaspace Neon",
  "buffer_font_family": "Monaspace Neon",
  "inlay_hints": {
    "enabled": false,
  },
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show": true,
  },
  "theme": "GitHub Dark",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": true,
    "enable_preview_from_file_finder": false,
    "enable_preview_from_multibuffer": false,
    "enable_preview_multibuffer_from_code_navigation": false,
    "enable_preview_file_from_code_navigation": false,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "status_bar": {
    "active_language_button": false,
    "cursor_position_button": false,
    // NOTE: This might change in the future.
    "experimental.show": true,
  },
  "wrap_guides": [100],
  "show_wrap_guides": true,
  "completion_menu_scrollbar": "auto",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "git_hosting_providers": [
    {
      "provider": "github",
      "name": "Epic Github",
      "base_url": "https://github.ol.epicgames.net",
    },
    {
      "provider": "github",
      "name": "Open Github",
      "base_url": "https://github.com",
    },
  ],
}
