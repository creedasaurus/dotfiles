# env.nu — loaded before config.nu

# XDG directories
$env.XDG_CACHE_HOME = ($env.HOME | path join ".cache")
$env.XDG_CONFIG_HOME = ($env.HOME | path join ".config")
$env.XDG_DATA_HOME = ($env.HOME | path join ".local/share")
$env.XDG_STATE_HOME = ($env.HOME | path join ".local/state")

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew
$env.HOMEBREW_PREFIX = "/opt/homebrew"
$env.HOMEBREW_CELLAR = "/opt/homebrew/Cellar"
$env.HOMEBREW_REPOSITORY = "/opt/homebrew"
{{ end -}}

# Secrets (rendered by chezmoi from 1Password)
source ($nu.default-config-dir | path join "secrets.nu")

# Generate tool init files into vendor/
mkdir ($nu.default-config-dir | path join "vendor")
^mise activate nu | save --force ($nu.default-config-dir | path join "vendor/mise.nu")
^starship init nu | save --force ($nu.default-config-dir | path join "vendor/starship.nu")
^zoxide init nushell | save --force ($nu.default-config-dir | path join "vendor/zoxide.nu")
^atuin init nu | save --force ($nu.default-config-dir | path join "vendor/atuin.nu")
^carapace _carapace nushell | save --force ($nu.default-config-dir | path join "vendor/carapace.nu")
